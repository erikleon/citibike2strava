# Copy to .env and fill in your own OAuth app credentials.
# Each user registers their OWN apps — no shared credentials ship with this tool.
# See docs/OAUTH_SETUP.md for step-by-step registration.
#
# .env is git-ignored. Never commit real secrets.

# --- Google Cloud OAuth client (Desktop app type) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Strava API application ---
STRAVA_CLIENT_ID=12345
STRAVA_CLIENT_SECRET=your-strava-client-secret

# --- Optional overrides ---
# CITIBIKE2STRAVA_TZ=America/New_York
# CITIBIKE2STRAVA_GMAIL_QUERY=from:updates.citibikenyc.com subject:"Ride Receipt"
# CITIBIKE2STRAVA_LABEL=citibike2strava/uploaded
